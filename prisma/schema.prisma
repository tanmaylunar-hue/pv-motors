generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

enum VehicleCategory {
  scooter
  motorcycle
  loader
}

enum StockStatus {
  in_stock
  low_stock
  out_of_stock
  pre_order
}

enum OrderStatus {
  pending
  confirmed
  fulfilled
  cancelled
}

enum EnquiryStatus {
  new
  contacted
  scheduled
  closed
}

model Vehicle {
  id        String          @id @default(cuid())
  name      String
  category  VehicleCategory
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  variants  Variant[]

  @@map("vehicles")
}

model Variant {
  id             String      @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name           String
  slug           String      @unique
  tagline        String
  price          Int
  specifications Json        @default("[]")
  images         Json        @default("[]")
  images360      Json        @default("[]")
  sequence       Int         @default(0)
  stockStatus    StockStatus @default(in_stock)
  stockQuantity  Int         @default(6)
  featured       Boolean     @default(false)
  highlights     Json        @default("[]")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orders         Order[]
  enquiries      Enquiry[]
  locks            VehicleLock[]
  drafts           VehicleDraft[]
  variantHistories VariantHistory[]

  @@map("variants")
}

model Order {
  id            String      @id @default(cuid())
  variantId     String
  variant       Variant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  customerName  String
  customerEmail String
  customerPhone String
  status        OrderStatus @default(pending)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("orders")
}

model Enquiry {
  id          String        @id @default(cuid())
  name        String
  phone       String
  address     String
  city        String
  state       String
  vehicleName String
  variantName String
  status      EnquiryStatus @default(new)
  variantId   String?
  variant     Variant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("enquiries")
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  category  String
  title     String?
  tagline   String?
  published Boolean  @default(true)
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_images")
}

enum AdminRole {
  owner
  manager
}

model AdminUser {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  role      AdminRole  @default(manager)
  disabled  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
  locks            VehicleLock[]
  drafts           VehicleDraft[]
  variantHistories VariantHistory[]

  @@map("admin_users")
}

model AuditLog {
  id        String     @id @default(cuid())
  adminId   String?
  admin     AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  actorName String
  action    String
  details   String
  timestamp DateTime   @default(now())

  @@map("audit_logs")
}

model VehicleLock {
  id        String    @id @default(cuid())
  variantId String    @unique
  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("vehicle_locks")
}

model VehicleDraft {
  id        String    @id @default(cuid())
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  variantId String
  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  data      Json
  updatedAt DateTime  @updatedAt

  @@unique([adminId, variantId])
  @@map("vehicle_drafts")
}

model VariantHistory {
  id        String    @id @default(cuid())
  variantId String
  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  adminId   String?
  admin     AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  data      Json
  createdAt DateTime  @default(now())

  @@map("variant_histories")
}

model DashboardNotification {
  id        String   @id @default(cuid())
  role      String
  type      String
  message   String
  createdAt DateTime @default(now())

  @@map("dashboard_notifications")
}

